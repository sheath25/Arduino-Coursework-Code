#include <IskakINO_LiquidCrystal_I2C.h>
#include <NewPing.h>
#define TANK_HEIGHT 30

NewPing sonar(8, 8, 30); 
LiquidCrystal_I2C lcd(16, 2); 

void calibrate() {
pinMode(13, OUTPUT);
digitalWrite(13, HIGH);
while (millis() < 10000){}
}

void setup() {
  // initialise serial communication:
  Serial.begin(9600);
  lcd.begin();
  lcd.print("  CALIBRATION  ");
calibrate();                                                                                                                                                                                                                         
 lcd.setCursor(0, 0);
 pinMode(13, OUTPUT);
digitalWrite(13, LOW); 
lcd.print(" Getting Reading");

pinMode(7, OUTPUT);
pinMode(6, OUTPUT);
pinMode(5, OUTPUT);
}

void loop() { 
 
 float distance = sonar.ping_cm(); 
  // establish variables for duration of the ping, and the distance result in centimeters:
  float level = (TANK_HEIGHT - distance) / TANK_HEIGHT * 100; 


// (looping different states) constantly checking the fill of the tank by printing high or low
// HIGH level
  if (level > 70 && level < 100) {
    // set pin (7) true for RED LED in series with the alarm
  digitalWrite(7, HIGH);
  digitalWrite(6, LOW);
  digitalWrite(5, LOW);

  lcd.setCursor(0, 0);
  lcd.print("   HIGH LEVEL      ");
  Serial.print(level);
  Serial.println("% - High Level");

  delay(100);
}
//Okay level
else if (level <= 70 && level > 35) {
  // set pin (6) true for ORANGE LED
  digitalWrite(6, HIGH);
  digitalWrite(7, LOW);
  digitalWrite(5, LOW);

  lcd.setCursor(0, 0);
  lcd.print("   PUMP START        ");
  lcd.setCursor(0, 1);
  lcd.print("             ");
  Serial.print(level);
  Serial.println("% - Pump Start");

  delay(100);
}
//LOW level
  else if (level <= 35 && level >= 0) {
  // set pin (5) true for GREEN LED
  digitalWrite(5, HIGH);
  digitalWrite(6, LOW);
  digitalWrite(7, LOW);

  lcd.setCursor(0, 0);
  lcd.print("   LOW LEVEL       ");
  lcd.setCursor(0, 1);
  lcd.print("             ");

    Serial.print(level);
    Serial.println("% - Low Level");

  delay(100);
  }
}
  



