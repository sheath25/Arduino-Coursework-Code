#include <IskakINO_LiquidCrystal_I2C.h>
#include <NewPing.h>
#include <Arduino.h>

#define TANK_HEIGHT  30// (change tank height in centimeters)

const int buttonPin = 2;
const int pumpPin = 3;

unsigned long countdownStartTime = 0;
bool countdownStarted = false;
bool pumpManual = false;
bool pumpAuto = false;

int buttonState;
int lastButtonState = HIGH;

NewPing sonar(8, 8, 30);
LiquidCrystal_I2C lcd(16, 2);

String tankState = getStateFromDistance(distance);

String getStateFromDistance(float distance) {
float level = (30 - distance) / 30 * 100;  // calculate % full, assuming tank is 30 cm (change 30 to required tank size)

if (level > 70) return "HIGH LEVEL";       // mostly full
else if (level > 35) return "PUMP START"; // medium
else if (level >= 0) return "LOW LEVEL";  // low
else return "OUT OF RANGE";               // impossible reading
}

