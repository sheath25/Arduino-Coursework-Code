
#include <IskakINO_LiquidCrystal_I2C.h>
#include <NewPing.h>
#define TANK_HEIGHT 30

NewPing sonar(8, 8, 30); 
LiquidCrystal_I2C lcd(16, 2); 

void calibrate() {
pinMode(13, OUTPUT);
digitalWrite(13, HIGH);
while (millis() < 10000){}
}

void setup() {
  // initialise serial communication:
  Serial.begin(9600);
  lcd.begin();
  lcd.print("CALIBRATION");

calibrate();                                                                                                                                                                                                                         
 lcd.setCursor(0, 0);
 // BLUE LED is true when calibrating
 pinMode(13, OUTPUT);
digitalWrite(13, LOW);

pinMode(7, OUTPUT);
pinMode(6, OUTPUT);
pinMode(5, OUTPUT);
}

void loop() {

  float total = 0;

for (int i = 0; i < 3; i++) {
  total += sonar.ping_cm();
  delay(10);
}

float distance = total / 3;

if (distance == 0) return;

}
digitalWrite(5, LOW);
digitalWrite(6, LOW);
digitalWrite(7, LOW);

// For smoother readings from the sensor
float distance = sonar.ping_cm();
delay(50);
float distance2 = sonar.ping_cm();

distance = (distance + distance2) / 2;

  // establish variables for duration of the ping, and the distance result in percentages:
  float level = ( distance) / TANK_HEIGHT * 100; 


// (looping different states) constantly checking the fill of the tank by printing high or low
// HIGH level 70-100%
  if (level <= 35 && level > 2) {
    // set pin (?) true for RED LED
   digitalWrite(7, HIGH);
   digitalWrite(6, LOW);
   digitalWrite(5, LOW);

     lcd.setCursor(0, 0);
    lcd.print("   HIGH LEVEL      ");

    Serial.print(level);
    Serial.println("% - High Level");

  delay(100);
}
//Okay level 35-70%
else if (level <= 70 && level > 35) {
  // set pin (?) true for ORANGE LED
    digitalWrite(6, HIGH);
    digitalWrite(7, LOW);
    digitalWrite(5, LOW);

    lcd.setCursor(0, 0);
    lcd.print("   Level OK        ");
  
    Serial.print(level);
    Serial.println("% - Level OK");

  delay(100);
}
//LOW level 0-35%
  else if (level > 70 && level < 100) {
  // set pin (?) true for GREEN LED
  // set same pin or different pin true for ALARM
  digitalWrite(5, HIGH);
  digitalWrite(6, LOW);
  digitalWrite(7, LOW);

   lcd.setCursor(0, 0);
    lcd.print("   LOW LEVEL       ");

    Serial.print(level);
    Serial.println("% - Low Level");

  delay(100);
  }
  else if (level < 2) {
  Serial.print(level);
  Serial.println(" % - NO READING");
  
  lcd.setCursor(0, 0);
  lcd.print("   NO READING   ");

digitalWrite(5, LOW);
digitalWrite(6, LOW);
digitalWrite(7, LOW);
  }
  
